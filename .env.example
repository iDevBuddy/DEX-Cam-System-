# Copy this file to .env and fill in what you have.
# Everything here is OPTIONAL — the demo runs without any of it.

# --- LLM report writer (either one; OpenRouter preferred) ---
# OpenRouter (https://openrouter.ai/keys) — Gemma 4 free tier works well.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
# Or Google Gemini direct (https://aistudio.google.com/apikey)
# If both empty, reports use a built-in template (still works fine).
GEMINI_API_KEY=

# --- Email delivery (Gmail: create an "App Password" in Google Account settings) ---
# If empty, reports are saved to reports/ folder and shown in dashboard only.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=

# Copy this file to .env and fill in what you have.
# Everything here is OPTIONAL — the demo runs without any of it.

# --- LLM report (Google Gemini free tier: https://aistudio.google.com/apikey) ---
# If empty, reports use a built-in template (still works fine).
GEMINI_API_KEY=

# --- Email delivery (Gmail: create an "App Password" in Google Account settings) ---
# If empty, reports are saved to reports/ folder and shown in dashboard only.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=
